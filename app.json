{
  "expo": {
    "name": "Paws&Love",
    "slug": "Kototeka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kototeka",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Приложение сохраняет изображения в фотопленку",
        "NSPhotoLibraryUsageDescription": "Приложение получает доступ к фотопленке для сохранения изображений"
      },
      "bundleIdentifier": "com.anonymous.Kototeka"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ],
      "package": "com.anonymous.Kototeka",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f9fafc",
          "image": "./assets/Images/splash.png",
          "imageWidth": 1080,
          "resizeMode": "cover"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Разрешить доступ к фото",
          "savePhotosPermission": "Разрешить сохранение фото",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/Images/notification.png",
          "color": "#000000",
          "sounds": [
            "./assets/sounds/notification.mp3"
          ]
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "433f97d5-331e-4cf8-956c-72a6022f9efb"
      }
    },
    "owner": "animasola"
  }
}
